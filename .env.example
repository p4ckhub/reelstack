# ==========================================
# APP (required)
# ==========================================
AUTH_SECRET=  # Generate with: openssl rand -base64 32
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ==========================================
# POSTGRES (required)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reelstack
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reelstack
# DATABASE_READ_URL=            # Read replica URL (optional - listing/analytics queries route here)

# ==========================================
# REDIS (required for server-side rendering)
# ==========================================
REDIS_PORT=6379
REDIS_PASSWORD=reelstack-dev
REDIS_URL=redis://:reelstack-dev@localhost:6379

# ==========================================
# MINIO (required for VPS mode storage)
# ==========================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reelstack
MINIO_USE_SSL=false  # Set to "true" for HTTPS connections to MinIO

# ==========================================
# SECURITY (optional)
# ==========================================
# HSTS_MAX_AGE=63072000  # HSTS max-age in seconds (default: 63072000 = 2 years, set to 0 to disable)

# ==========================================
# EMAIL / MAGIC LINKS (required - magic link auth)
# ==========================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxx
EMAIL_FROM=noreply@yourdomain.com

# ==========================================
# CLOUD MODE: Supabase Storage (optional)
# ==========================================
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=reelstack

# ==========================================
# CLOUD MODE: Inngest Queue (optional)
# ==========================================
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# ==========================================
# REEL PIPELINE (optional - for reel generation)
# ==========================================
# ELEVENLABS_API_KEY=     # ElevenLabs TTS (PL voice clone). Free fallback: edge-tts
# ANTHROPIC_API_KEY=      # AI Director (falls back to rule-based without key)
# PEXELS_API_KEY=         # B-roll stock footage search
# REMOTION_RENDERER=local # local (default) or lambda
# REMOTION_CONCURRENCY=   # Parallel frames. Default: 50% of CPU cores

# ==========================================
# PUBLISHING via Postiz (optional)
# ==========================================
# POSTIZ_API_URL=http://localhost:4200
# POSTIZ_API_KEY=

# ==========================================
# SELLF INTEGRATION (optional - tier/token purchases)
# ==========================================
# SELLF_WEBHOOK_SECRET=
# SELLF_PRODUCT_SOLO=          # Sellf product ID → SOLO tier ($9/mo)
# SELLF_PRODUCT_PRO=           # Sellf product ID → PRO tier ($24/mo)
# SELLF_PRODUCT_AGENCY=        # Sellf product ID → AGENCY tier ($79/mo)
# SELLF_PRODUCT_10_TOKENS=     # Token pack: 10 renders ($5)
# SELLF_PRODUCT_50_TOKENS=     # Token pack: 50 renders ($19)
# SELLF_PRODUCT_150_TOKENS=    # Token pack: 150 renders ($49)
# SELLF_PRODUCT_500_TOKENS=    # Token pack: 500 renders ($129)

# ==========================================
# REMOTION LAMBDA (optional - serverless rendering)
# ==========================================
# Set REMOTION_RENDERER=lambda above, then configure:
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# REMOTION_LAMBDA_FUNCTION_NAME=    # From: bunx remotion lambda functions ls
# REMOTION_LAMBDA_SERVE_URL=        # From: bunx remotion lambda sites ls

# ==========================================
# WEBHOOK CALLBACKS (optional)
# ==========================================
# WEBHOOK_CALLBACK_SECRET=your-hmac-secret   # Signs webhook payloads (X-ReelStack-Signature header)

# ==========================================
# PROMETHEUS METRICS (optional)
# ==========================================
# METRICS_TOKEN=your-secret-token

# ==========================================
# SENTRY (optional - error tracking)
# ==========================================
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=reelstack

# ==========================================
# E2E TESTING (optional)
# ==========================================
# OPENROUTER_API_KEY=  # For AI-powered screenshot analysis in Playwright E2E tests (free models available)
