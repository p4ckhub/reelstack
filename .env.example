# ==========================================
# APP (required)
# ==========================================
AUTH_SECRET=  # Generate with: openssl rand -base64 32
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ==========================================
# POSTGRES (required)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reelstack
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reelstack
# DATABASE_READ_URL=            # Read replica URL (optional - listing/analytics queries route here)

# ==========================================
# REDIS (required for server-side rendering)
# ==========================================
REDIS_PORT=6379
REDIS_PASSWORD=reelstack-dev
REDIS_URL=redis://:reelstack-dev@localhost:6379

# ==========================================
# MINIO (required for VPS mode storage)
# ==========================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reelstack
MINIO_USE_SSL=false  # Set to "true" for HTTPS connections to MinIO

# ==========================================
# SECURITY (optional)
# ==========================================
# HSTS_MAX_AGE=63072000  # HSTS max-age in seconds (default: 63072000 = 2 years, set to 0 to disable)

# ==========================================
# EMAIL / MAGIC LINKS (required - magic link auth)
# ==========================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxx
EMAIL_FROM=noreply@yourdomain.com

# ==========================================
# CLOUD MODE: Supabase Storage (optional)
# ==========================================
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=reelstack

# ==========================================
# CLOUD MODE: Inngest Queue (optional)
# ==========================================
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# ==========================================
# REEL PIPELINE - LLM (optional)
# ==========================================
# ANTHROPIC_API_KEY=      # AI Director (primary LLM provider)
# OPENAI_API_KEY=         # OpenAI fallback
# OPENROUTER_API_KEY=     # OpenRouter fallback (also used by prompt-writer)
# MODEL_PRESET=production # LLM model preset: production | fast | cheap
# SCRIPT_REVIEW=          # Enable script review pass (true/false)
# REVIEWER_MODEL=         # Override model for script reviewer (e.g. claude-sonnet-4-6)
# PROMPT_WRITER=          # Enable prompt writer pass (true/false)

# ==========================================
# REEL PIPELINE - TTS (optional)
# ==========================================
# ELEVENLABS_API_KEY=     # ElevenLabs TTS (PL voice clone). Free fallback: edge-tts

# ==========================================
# REEL PIPELINE - VIDEO GENERATION (optional)
# ==========================================
# FAL_KEY=                # fal.ai video generation
# KIE_API_KEY=            # Kie video generation
# PIAPI_KEY=              # PiAPI video generation
# WAVESPEED_API_KEY=      # WaveSpeed video generation
# REPLICATE_API_TOKEN=    # Replicate video generation
# AIMLAPI_KEY=            # AIML API (video + image + TTS)
# RUNWAY_API_KEY=         # Runway Gen video generation
# MINIMAX_API_KEY=        # MiniMax video generation
# MINIMAX_MODEL=video-01-live  # MiniMax model override
# KLING_API_KEY=          # Kling video generation
# KLING_MODEL=kling-v2.1-master  # Kling model override
# SEEDANCE_API_KEY=       # Seedance video generation
# SEEDANCE_API_BASE=      # Seedance API base URL override
# SEEDANCE_MODEL=seedance-1.0   # Seedance model override

# ==========================================
# REEL PIPELINE - GOOGLE (Veo, Gemini)
# ==========================================
# VEO3_API_KEY=           # Veo 3.0 API key
# VEO3_PROJECT_ID=        # Veo 3.0 GCP project ID
# VEO3_LOCATION=us-central1   # Veo 3.0 location
# VEO3_MODEL=veo-3.0-generate-001  # Veo 3.0 model
# VERTEX_PROJECT_ID=      # Vertex AI / Veo 3.1 project ID
# VEO31_MODEL=veo-3.1-generate-001  # Veo 3.1 model

# ==========================================
# REEL PIPELINE - IMAGE GENERATION (optional)
# ==========================================
# NANOBANANA_API_KEY=     # NanoBanana image gen (falls back to GEMINI_API_KEY)
# NANOBANANA_MODEL=gemini-3.1-flash-image-preview  # NanoBanana model override
# GEMINI_API_KEY=         # Google Gemini (image gen fallback)

# ==========================================
# REEL PIPELINE - AVATAR (optional)
# ==========================================
# HEYGEN_API_KEY=         # HeyGen avatar video generation
# HEYGEN_AVATAR_ID=       # Default avatar ID
# HEYGEN_VOICE_ID=        # Default voice ID
# HEYGEN_TEST_MODE=false  # Enable HeyGen test mode (no credits consumed)

# ==========================================
# REEL PIPELINE - STOCK FOOTAGE (optional)
# ==========================================
# PEXELS_API_KEY=         # B-roll stock footage search
# PEXELS_ENABLED=false    # Enable Pexels stock footage

# ==========================================
# REEL PIPELINE - SELF-HOSTED (optional)
# ==========================================
# RUNPOD_API_KEY=         # RunPod serverless GPU
# HUMO_RUNPOD_ENDPOINT_ID=  # Humo avatar RunPod endpoint
# HUMO_DEFAULT_IMAGE_URL= # Default avatar image for Humo

# ==========================================
# REEL PIPELINE - RENDERING (optional)
# ==========================================
# REMOTION_RENDERER=local # local (default) or lambda
# REMOTION_CONCURRENCY=   # Parallel frames. Default: 50% of CPU cores

# ==========================================
# N8N MODULE (optional - for n8n-explainer videos)
# ==========================================
# N8N_BASE_URL=http://localhost:5678
# N8N_EMAIL=
# N8N_PASSWORD=

# ==========================================
# PUBLISHING via Postiz (optional)
# ==========================================
# POSTIZ_API_URL=http://localhost:4200
# POSTIZ_API_KEY=

# ==========================================
# SELLF INTEGRATION (optional - tier/token purchases)
# ==========================================
# SELLF_WEBHOOK_SECRET=
# SELLF_PRODUCT_SOLO=          # Sellf product ID → SOLO tier ($9/mo)
# SELLF_PRODUCT_PRO=           # Sellf product ID → PRO tier ($24/mo)
# SELLF_PRODUCT_AGENCY=        # Sellf product ID → AGENCY tier ($79/mo)
# SELLF_PRODUCT_10_TOKENS=     # Token pack: 10 renders ($5)
# SELLF_PRODUCT_50_TOKENS=     # Token pack: 50 renders ($19)
# SELLF_PRODUCT_150_TOKENS=    # Token pack: 150 renders ($49)
# SELLF_PRODUCT_500_TOKENS=    # Token pack: 500 renders ($129)

# ==========================================
# REMOTION LAMBDA (optional - serverless rendering)
# ==========================================
# Set REMOTION_RENDERER=lambda above, then configure:
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# REMOTION_LAMBDA_FUNCTION_NAME=    # From: bunx remotion lambda functions ls
# REMOTION_LAMBDA_SERVE_URL=        # From: bunx remotion lambda sites ls

# ==========================================
# WEBHOOK CALLBACKS (optional)
# ==========================================
# WEBHOOK_CALLBACK_SECRET=your-hmac-secret   # Signs webhook payloads (X-ReelStack-Signature header)

# ==========================================
# PROMETHEUS METRICS (optional)
# ==========================================
# METRICS_TOKEN=your-secret-token

# ==========================================
# SENTRY (optional - error tracking)
# ==========================================
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=reelstack

# ==========================================
# E2E TESTING (optional)
# ==========================================
# OPENROUTER_API_KEY=  # For AI-powered screenshot analysis in Playwright E2E tests (free models available)
