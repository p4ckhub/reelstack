{
  "name": "reelstack",
  "private": true,
  "license": "AGPL-3.0",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "bun test packages/core && bun test packages/tts && bun test packages/transcription && bun test packages/ffmpeg && bun test packages/storage && bun test packages/queue && bun test packages/database && bun test packages/image-gen && bun test packages/remotion && bun test packages/modules && bun test packages/agent && bun test apps/web/src",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "api:seed": "bun scripts/dev-seed.ts",
    "api:test": "npx @usebruno/cli run bruno/reelstack --env local",
    "api:test:validation": "npx @usebruno/cli run bruno/reelstack/validation --env local",
    "rs": "bun packages/agent/src/cli.ts"
  },
  "overrides": {
    "fast-xml-parser": ">=5.3.6",
    "nodemailer": ">=7.0.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "bunx prettier --check"
    ]
  },
  "devDependencies": {
    "altcha": "^3.0.2",
    "happy-dom": "^20.8.9",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "~6.3.1",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "web": "workspace:*"
  },
  "dependencies": {
    "altcha-lib": "^1.4.1"
  }
}
