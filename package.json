{
  "name": "reelstack",
  "private": true,
  "license": "AGPL-3.0",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "api:seed": "bun scripts/dev-seed.ts",
    "seed:reference-bank": "bun scripts/seed-reference-bank.ts",
    "api:test": "npx @usebruno/cli run bruno/reelstack --env local",
    "api:test:validation": "npx @usebruno/cli run bruno/reelstack/validation --env local",
    "rs": "bun packages/agent/src/cli.ts"
  },
  "overrides": {
    "fast-xml-parser": ">=5.7.0",
    "nodemailer": ">=8.0.0",
    "postcss": ">=8.5.10"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "bunx prettier --check"
    ]
  },
  "devDependencies": {
    "altcha": "^3.0.4",
    "happy-dom": "^20.9.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prisma": "~6.19.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "web": "workspace:*"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "altcha-lib": "^1.4.1"
  }
}
