{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tests/**",
        "package.json",
        "tsconfig.json",
        "vitest.config.ts",
        "../../vitest.shared.ts"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "remotion:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
