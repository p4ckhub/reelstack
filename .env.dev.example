# ============================================================
# ReelStack — Local dev environment (.env.dev)
# ============================================================
# Copy this file to .env.dev and fill in your API keys, then run:
#     docker compose -f docker-compose.dev.yml up -d --build
# ============================================================

# ──────────────────────────────────────────────────────────
#  Infrastructure (all in docker-compose.dev.yml)
# ──────────────────────────────────────────────────────────

# Postgres (container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reelstack_dev
POSTGRES_PORT=5433
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/reelstack_dev # trufflehog:ignore
# Separate URL used on the host (e.g. `bun run prisma db push` from your terminal)
DATABASE_URL_HOST=postgresql://postgres:postgres@localhost:5433/reelstack_dev # trufflehog:ignore

# Redis (container)
REDIS_PORT=6379
REDIS_PASSWORD=reelstack-dev
REDIS_URL=redis://:reelstack-dev@redis:6379

# MinIO (container — S3-compatible)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=reelstack
MINIO_SECRET_KEY=reelstack-dev-secret
MINIO_BUCKET=reelstack-dev

# ──────────────────────────────────────────────────────────
#  App
# ──────────────────────────────────────────────────────────

NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Auth — random string, unique per environment
AUTH_SECRET=dev-only-secret-change-me-to-something-random-32chars
AUTH_TRUST_HOST=true
AUTH_URL=http://localhost:3001

# Dev login: allow sign-in with any email, no password, no SMTP required.
# Only works when NODE_ENV=development (hard-gated in code).
ALLOW_DEV_LOGIN=1
NEXT_PUBLIC_ALLOW_DEV_LOGIN=1

# SMTP is NOT required in dev (use Dev Login button). Leave empty.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@localhost

# Renderer: `local` = headless Chromium in the worker container.
REMOTION_RENDERER=local

# Pipeline engine (default is fine)
PIPELINE_ENGINE=production

# ──────────────────────────────────────────────────────────
#  API keys — REQUIRED for full pipeline
# ──────────────────────────────────────────────────────────
# Replace with your own keys. Leave others empty; pipeline will use
# free/local providers by default (edge-tts, whisper-cpp).

# Anthropic (Claude) — used by the AI Director / planner. REQUIRED.
ANTHROPIC_API_KEY=

# Whisper transcription: OpenAI (direct) OR OpenRouter. Pick one.
# Needed for karaoke captions. Without it, transcription step will fail.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ──────────────────────────────────────────────────────────
#  Optional providers (leave empty to skip)
# ──────────────────────────────────────────────────────────

# ElevenLabs — premium TTS. edge-tts (free, no key) is the default.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Image gen (for talking-object module etc.). Pick one:
FAL_KEY=
GEMINI_API_KEY=
NANOBANANA_API_KEY=
AIMLAPI_KEY=

# Video gen (avatar layouts)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
KLING_API_KEY=
MINIMAX_API_KEY=

# Cloudflare R2 (if you want production-like storage instead of MinIO)
# CF_ACCOUNT_ID=
# CF_API_TOKEN=

# ──────────────────────────────────────────────────────────
#  Altcha — proof-of-work captcha. AUTH_SECRET is reused by default.
# ──────────────────────────────────────────────────────────
# ALTCHA_HMAC_KEY=
