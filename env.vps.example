# ============================================================
# PRESET: VPS Full (Mikrus / self-hosted)
# ============================================================
# Queue:   BullMQ + Redis (container)
# Storage: MinIO (container, local disk)
# Render:  Local worker (container)
#
# Uruchomienie:
#   cp env.vps.example .env
#   docker compose -f docker-compose.prod.yml up -d
# ============================================================

# --- Required ---
AUTH_SECRET=change-me-at-least-32-characters-long
DATABASE_URL=postgresql://reelstack:CHANGE_ME@postgres:5432/reelstack  # trufflehog:ignore

# --- Redis (BullMQ queue) ---
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# --- MinIO (local S3-compatible storage) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME_SECRET
MINIO_BUCKET=reelstack
MINIO_USE_SSL=false

# --- PostgreSQL ---
POSTGRES_USER=reelstack
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=reelstack

# --- Remotion render ---
REMOTION_RENDERER=local

# --- AI (agent planner) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- TTS (at least one) ---
# Edge TTS is free, no key needed (default)
# ELEVENLABS_API_KEY=...
# OPENAI_API_KEY=...

# --- AI Video Tools (optional, enable what you have) ---
# PEXELS_API_KEY=...
# HEYGEN_API_KEY=...
# VEO3_API_KEY=...
# VEO3_PROJECT_ID=...
# VEO3_LOCATION=us-central1
# KLING_API_KEY=...
# SEEDANCE_API_KEY=...
# NANOBANANA_API_KEY=...    # or GEMINI_API_KEY
# GEMINI_API_KEY=...

# --- Email / magic links (optional) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# EMAIL_FROM=noreply@example.com

# --- App ---
NODE_ENV=production
