# ============================================================
# PRESET: Cloud (Supabase + Inngest + Lambda)
# ============================================================
# Queue:   Inngest (serverless, no Redis)
# Storage: Supabase Storage
# Render:  AWS Lambda
#
# Kiedy używać:
#   - Brak VPS lub nie chcesz zarządzać infrastrukturą
#   - Chcesz deploy na Vercel/Railway bez persistent workers
#   - Scale-to-zero (płacisz tylko za faktyczne użycie)
#
# Wymagane konta:
#   - Supabase (supabase.com) - free tier wystarczy na start
#   - Inngest (inngest.com) - free tier: 50k events/miesiąc
#   - AWS (dla Lambda render)
#
# Setup Lambda (jednorazowo):
#   AWS_REGION=eu-central-1 npx tsx packages/remotion/scripts/deploy-lambda.ts
#
# Uwaga: NIE uruchamiaj docker-compose w tym trybie.
#   Web app deploy na Vercel/Railway. Worker = Inngest functions.
# ============================================================

# --- Required ---
AUTH_SECRET=change-me-at-least-32-characters-long
DATABASE_URL=postgresql://...    # Supabase connection string

# --- Inngest (queue, replaces Redis + BullMQ) ---
INNGEST_EVENT_KEY=...            # z Inngest dashboard
INNGEST_SIGNING_KEY=...          # z Inngest dashboard

# --- Supabase (auth + storage) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_STORAGE_BUCKET=videos

# --- Lambda Render ---
REMOTION_RENDERER=lambda
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
REMOTION_LAMBDA_FUNCTION_NAME=remotion-render-...
REMOTION_LAMBDA_SERVE_URL=https://s3.eu-central-1.amazonaws.com/...

# --- AI (agent planner) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- TTS ---
# ELEVENLABS_API_KEY=...
# OPENAI_API_KEY=...

# --- AI Video Tools (optional) ---
# PEXELS_API_KEY=...
# HEYGEN_API_KEY=...
# VEO3_API_KEY=...
# VEO3_PROJECT_ID=...
# KLING_API_KEY=...
# SEEDANCE_API_KEY=...
# GEMINI_API_KEY=...

# --- Email ---
# SMTP_HOST=...
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
# EMAIL_FROM=noreply@example.com

# --- App ---
NODE_ENV=production
