meta {
  name: Matrix - Fork-Only (no language axis = 1 base)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/reel/matrix
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "base": {
      "mode": "n8n-explainer",
      "workflowUrl": "https://n8n.io/workflows/2813-automate-content-generator-for-wordpress-with-deepseek-r1",
      "language": "pl",
      "runtime": "hyperframes",
      "endCard": { "durationSeconds": 4 }
    },
    "dimensions": {
      "endCard.platform": ["ig", "fb", "tiktok", "youtube", "linkedin", "universal"]
    }
  }
}

docs {
  Render the same PL reel for all 6 platforms. No `language` dim → only
  1 base full pipeline + 5 free platform forks. Cost: 10 credits, ~6 min.

  This is the most common matrix shape — same reel, different CTA copy
  per network. Compare to:
    /matrix with `language: [pl,en]` × 6 plats = 12 cells, 20 credits
}
