meta {
  name: Generate - AI Short Film
  type: http
  seq: 15
}

post {
  url: {{baseUrl}}/api/v1/reel/generate
  body: json
  auth: bearer
}

auth:bearer {
  token: {{apiKey}}
}

body:json {
  {
    "mode": "ai-short-film",
    "topic": "A solo developer ships their first SaaS at 3 AM and finally goes to sleep",
    "style": "cinematic",
    "language": "en",
    "endCard": {
      "platform": "youtube",
      "headline": "Subscribe for more",
      "subheadline": "New film every week"
    }
  }
}

script:post-response {
  if (res.status === 201) bru.setVar("jobId", res.body.data.jobId);
}

docs {
  Cinematic narrative: LLM writes a multi-shot script, plans visuals, calls
  Veo/Kling/Seedance per shot, stitches with crossfades. `spotlight` card
  by default (dramatic outro). Expensive — uses video providers per shot.
}
